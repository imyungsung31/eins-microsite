{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/product/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Pretendard|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Pretendard, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:flagship|value|accent|neutral)$/]",
        "message": "<Badge> tone must be one of 'flagship' | 'value' | 'accent' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|arrow|fullWidth|disabled|href|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, arrow, fullWidth, disabled, href, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|solidLight)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'solidLight'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|hover|glow|padding|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, hover, glow, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:light|panel|outline)$/]",
        "message": "<Card> variant must be one of 'light' | 'panel' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CompareProduct'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|model|recommended|key|ref|className|style|children)$/]",
        "message": "<CompareProduct> doesn't accept that prop. Declared props: name, model, recommended."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:accent|light|dark)$/]",
        "message": "<Eyebrow> color must be one of 'accent' | 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductSpec'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|highlight|key|ref|className|style|children)$/]",
        "message": "<ProductSpec> doesn't accept that prop. Declared props: label, value, unit, highlight."
      },
      {
        "selector": "JSXOpeningElement[name.name='BuildPart'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|name|highlight|key|ref|className|style|children)$/]",
        "message": "<BuildPart> doesn't accept that prop. Declared props: kind, name, highlight."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|eyebrow|style|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: title, subtitle, eyebrow, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpecRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|highlight|onDark|style|key|ref|className|style|children)$/]",
        "message": "<SpecRow> doesn't accept that prop. Declared props: label, value, unit, highlight, onDark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarRating'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|showValue|count|size|style|key|ref|className|style|children)$/]",
        "message": "<StarRating> doesn't accept that prop. Declared props: value, max, showValue, count, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatNumber'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|unit|delta|label|size|color|style|key|ref|className|style|children)$/]",
        "message": "<StatNumber> doesn't accept that prop. Declared props: value, unit, delta, label, size, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatNumber'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<StatNumber> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatNumber'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:accent|white|dark)$/]",
        "message": "<StatNumber> color must be one of 'accent' | 'white' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|soft|outline)$/]",
        "message": "<Tag> variant must be one of 'solid' | 'soft' | 'outline'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
